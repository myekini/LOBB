# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

SUPABASE_SERVICE_ROLE_KEY=

# Paystack
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=

# Twilio (OTP delivery)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# WhatsApp sender — set this to use WhatsApp OTP delivery (recommended for Nigeria)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_CONTENT_SID=
# Regular SMS fallback — only needed if not using WhatsApp
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# Resend (email)
RESEND_API_KEY=
EMAIL_FROM="LOBB <bookings@notifications.lobb.ng>"
EMAIL_REPLY_TO=support@lobb.ng
ADMIN_EMAIL=admin@lobb.ng

# PostHog (production analytics)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# App
NEXT_PUBLIC_APP_URL=https://lobb.ng
NEXT_PUBLIC_APP_NAME=LOBB
ADMIN_SECRET=
AUTH_EMAIL_DOMAIN=gmail.com
# Used to sign synthetic email passwords for phone-auth users (falls back to ADMIN_SECRET)
AUTH_SESSION_SECRET=

# Contact / social (optional — sensible defaults are used if unset)
NEXT_PUBLIC_LOBB_SUPPORT_EMAIL=support@lobb.ng
NEXT_PUBLIC_LOBB_SUPPORT_WHATSAPP=2348000000000
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/lobb.ng
NEXT_PUBLIC_X_URL=https://x.com/lobb_ng

# ── Local dev only — NEVER set these to true in production ──────────────────
# Test OTP applies only to the explicit dev phone numbers below.
# All other phone numbers receive real OTP codes regardless of this flag.
LOBB_TEST_OTP=000000
NEXT_PUBLIC_LOBB_TEST_OTP=000000
LOBB_ENABLE_TEST_OTP=false
LOBB_TEST_PHONE_NUMBERS=+2340000000001,+2340000000002
NEXT_PUBLIC_LOBB_TEST_PHONE_NUMBERS=+2340000000001,+2340000000002

# Dev quick-login buttons on the /auth/login page (set true in .env.local only)
#   Dev Player phone: +2340000000001  (OTP: 000000)
#   Dev Coach phone:  +2340000000002  (OTP: 000000)  slug: ada-okafor-dev
LOBB_ENABLE_DEV_LOGIN=false
NEXT_PUBLIC_LOBB_DEV_LOGIN=false

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Paystack
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=

# Termii (SMS)
TERMII_API_KEY=
TERMII_SENDER_ID=LOBB

# SMS provider. Production is SMS-first via Termii.
# Supported: termii, twilio, twilio_whatsapp.
SMS_PROVIDER=termii

# Optional Supabase/Twilio compatibility fallbacks.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM_NUMBER=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_CONTENT_SID=

# Resend
RESEND_API_KEY=

# App
NEXT_PUBLIC_APP_URL=https://lobb.ng
NEXT_PUBLIC_APP_NAME=LOBB
ADMIN_SECRET=
AUTH_EMAIL_DOMAIN=gmail.com

# ── Local dev only — NEVER set these to true in production ──────────────────
# Test OTP applies only to the explicit dev phone numbers below.
# All other phone numbers receive real SMS codes regardless of this flag.
LOBB_TEST_OTP=000000
NEXT_PUBLIC_LOBB_TEST_OTP=000000
LOBB_ENABLE_TEST_OTP=false
LOBB_TEST_PHONE_NUMBERS=+2340000000001,+2340000000002
NEXT_PUBLIC_LOBB_TEST_PHONE_NUMBERS=+2340000000001,+2340000000002

# Dev quick-login buttons on the /auth/login page (set true in .env.local only)
#   Dev Player phone: +2340000000001  (OTP: 000000)
#   Dev Coach phone:  +2340000000002  (OTP: 000000)  slug: ada-okafor-dev
LOBB_ENABLE_DEV_LOGIN=false
NEXT_PUBLIC_LOBB_DEV_LOGIN=false

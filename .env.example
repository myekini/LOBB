# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

SUPABASE_SERVICE_ROLE_KEY=

# Paystack
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=

# Termii — primary OTP + SMS provider for Nigeria (termii.com)
# When set, Termii is used for OTP delivery instead of Twilio
TERMII_API_KEY=
TERMII_SENDER_ID=LOBB
# Channel: "generic" (SMS), "dnd" (bypasses DND), "whatsapp" (WhatsApp Business)
TERMII_CHANNEL=generic

# Twilio — kept for WhatsApp Business notifications (non-OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_CONTENT_SID=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# Resend (email)
RESEND_API_KEY=
EMAIL_FROM="LOBB <bookings@notifications.lobb.ng>"
EMAIL_REPLY_TO=support@lobb.ng
# Comma-separated list of admin emails — provisioned via POST /api/admin/setup
ADMIN_EMAILS=lobbnigeria@gmail.com
# Long random secret for the /api/admin/setup endpoint — generate with: openssl rand -hex 32
ADMIN_SETUP_SECRET=

# PostHog (production analytics)
NEXT_PUBLIC_POSTHOG_KEY=
# Use /ingest to route through the Next.js reverse proxy (recommended)
NEXT_PUBLIC_POSTHOG_HOST=/ingest
# Set to "true" to disable PostHog event capture (e.g. for staging/internal environments)
NEXT_PUBLIC_POSTHOG_OPT_OUT=false

# Mixpanel (product analytics)
NEXT_PUBLIC_MIXPANEL_TOKEN=a7fd42f9bdc4327b3b07ea52384a467a
NEXT_PUBLIC_MIXPANEL_ENABLED=true

# App
NEXT_PUBLIC_APP_URL=https://lobb.ng
# Public HTTPS base for email-hosted images. Use production CDN/domain, not localhost.
NEXT_PUBLIC_EMAIL_ASSET_URL=https://lobb.ng
NEXT_PUBLIC_APP_NAME=LOBB
ADMIN_SECRET=
# Supabase Auth → Hooks → Send Email — shared secret (format: v1,whsec_<base64>)
# Generate in Supabase dashboard and copy the full string including the v1,whsec_ prefix.
SUPABASE_EMAIL_HOOK_SECRET=

# Contact / social (optional — sensible defaults are used if unset)
NEXT_PUBLIC_LOBB_SUPPORT_EMAIL=support@lobb.ng
NEXT_PUBLIC_LOBB_SUPPORT_WHATSAPP=2348000000000
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/lobb.ng
NEXT_PUBLIC_X_URL=https://x.com/lobb_ng

# Email OTP length — must match Supabase Auth "Email OTP Length" setting (dashboard)
NEXT_PUBLIC_OTP_LENGTH=6

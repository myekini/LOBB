# LOBB — gitignore

# Dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# Next.js build output
/.next/
/out/
/.vercel/output/
/build

# Testing
/coverage

# Misc
.DS_Store
Thumbs.db
*.pem

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files (all variants — never commit secrets)
.env
.env.local
.env.*.local
.env.prod
.env.production

# Vercel deployment
.vercel

# Local agent/tooling files
.agents/
.codex-logs/
skills-lock.json
.impeccable/

# Server process logs
*.out.log
*.err.log

# Supabase local metadata
supabase/.temp/

# TypeScript build cache
*.tsbuildinfo
next-env.d.ts
